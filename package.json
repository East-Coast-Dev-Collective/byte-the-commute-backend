{
  "name": "byte-the-commute-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Byte The Commute Backend serves as the database and backend for the Byte The Commute App",
  "main": "server.js",
  "scripts": {
    "test": "vitest",
    "start": "node --env-file=.env server.js",
    "dev": "nodemon --env-file=.env server.js",
    "test:weather": "node --env-file=.env tests/weatherTests.js",
    "test:weather:endpoint": "node --env-file=.env tests/weatherEndpointChecks.js",
    "db:schema": "psql -U byte_the_commute_user -h localhost -d byte_the_commute -f db/schema.sql"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/East-Coast-Dev-Collective/byte-the-commute-backend.git"
  },
  "author": "East Coast Dev Collective",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/East-Coast-Dev-Collective/byte-the-commute-backend/issues"
  },
  "homepage": "https://github.com/East-Coast-Dev-Collective/byte-the-commute-backend#readme",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "pg": "^8.18.0"
  }
}
